; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="cards_combat_game"
config/version="0.8.0"
config/tags=PackedStringArray("2d", "cards", "deck", "game")
run/main_scene="uid://cduyerybdtq7u"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="uid://dpe8ixn4tq0o0"

[autoload]

CardManager="*uid://csmlamigc885c"
DeckManager="*uid://b15f2f2s26mpw"
GlobalData="*uid://ds4saa4w4n7yk"
SaveManager="*uid://wsmh8wpfeill"
AudioManager="*uid://c7qnsx15cyyuu"
SceneLoader="*uid://drxxra1qcv8qt"
TooltipManager="*uid://dwougphpc3plb"
ConfigManager="*uid://dq4fpa7w2jdbu"
DebugOverlay="*uid://kwt4as8vekix"

[debug]

gdscript/warnings/untyped_declaration=1
gdscript/warnings/inferred_declaration=1
gdscript/warnings/narrowing_conversion=0

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=false
window/stretch/mode="canvas_items"

[gui]

theme/default_font_multichannel_signed_distance_field=true
theme/custom_font="uid://bkmp6cbx1sym3"

[internationalization]

locale/translations=PackedStringArray("res://resources/translations.en.translation", "res://resources/translations.es.translation")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
